y; color: rgb(8, 8, 8); font-family: &amp;quot;JetBrains Mono&amp;quot;, monospace; font-size: 11.3pt;&quot;&gt;SELECT JOB_ID FROM SCHEDULER&lt;/pre&gt;&lt;pre style=&quot;text-align: justify; color: rgb(8, 8, 8); font-family: &amp;quot;JetBrains Mono&amp;quot;, monospace; font-size: 11.3pt;&quot;&gt; WHERE&lt;/pre&gt;&lt;pre style=&quot;color: rgb(8, 8, 8); font-family: &amp;quot;JetBrains Mono&amp;quot;, monospace; font-size: 11.3pt;&quot;&gt;&lt;div style=&quot;text-align: justify;&quot;&gt;&lt;span style=&quot;font-size: 11.3pt; background-color: initial; white-space: normal;&quot;&gt;&amp;nbsp; TRUNC(SYSDATE)   = TRUNC(NEXT_EXECUTION_DATE)&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;text-align: justify;&quot;&gt;&lt;span style=&quot;font-size: 11.3pt; background-color: initial; white-space: normal;&quot;&gt;&amp;nbsp; &amp;nbsp; AND STATUS      != 'RUNNING'&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;text-align: justify;&quot;&gt;&lt;span style=&quot;font-size: 11.3pt; background-color: initial; white-space: normal;&quot;&gt;&amp;nbsp; &amp;nbsp; AND RETRY_COUNT  &amp;lt; 3&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;text-align: justify;&quot;&gt;&lt;span style=&quot;font-size: 11.3pt; background-color: initial; white-space: normal;&quot;&gt;&amp;nbsp; &amp;nbsp; OR&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;text-align: justify;&quot;&gt;&lt;span style=&quot;font-size: 11.3pt; background-color: initial; white-space: normal;&quot;&gt;&amp;nbsp; &amp;nbsp; LAST_EXECUTION_DATE IS NULL;&lt;/span&gt;&lt;/div&gt;&lt;/pre&gt;" style="rounded=1;whiteSpace=wrap;html=1;align=center;" parent="1" vertex="1"><mxGeometry x="-82" y="-204" width="404" height="205" as="geometry"/></mxCell><mxCell id="hxSikaWmdNY9C-RC8pGS-27" value="Polling jobs ready to run" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" parent="1" vertex="1"><mxGeometry x="122" y="137" width="147" height="26" as="geometry"/></mxCell><mxC