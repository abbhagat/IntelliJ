p;html=1;boundedLbl=1;backgroundOutline=1;size=15;fillColor=#f5f5f5;fontColor=#333333;strokeColor=#666666;" parent="1" vertex="1"><mxGeometry x="82" y="408" width="60" height="80" as="geometry"/></mxCell><mxCell id="RCRncxMgSl9sKIa2PNuL-5" value="Redis" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=15;fillColor=#f5f5f5;fontColor=#333333;strokeColor=#666666;" parent="1" vertex="1"><mxGeometry x="-1" y="408" width="50" height="80" as="geometry"/></mxCell><mxCell id="y92S8OUXR56Y96MIeaPX-1" value="&lt;div&gt;If asked &quot;Why do we use Redis in a notification system?&quot;, a concise answer is:&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;Cache user notification preferences and device tokens.&lt;/div&gt;&lt;div&gt;Implement rate limiting to prevent spam.&lt;/div&gt;&lt;div&gt;Deduplicate retried events using idempotency keys.&lt;/div&gt;&lt;div&gt;Maintain unread notification counters.&lt;/div&gt;&lt;div&gt;Track online users for WebSocket delivery.&lt;/div&gt;&lt;div&gt;Schedule delayed notifications using sorted sets.&lt;/div&gt;&lt;div&gt;Provide lightweight queues or Pub/Sub for real-time delivery.&lt;/div&gt;&lt;div&gt;Reduce database load while delivering notifications with very low latency&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" parent="1" vertex="1"><mxGeometry x="-203" y="708" width="434" height="156" as="geometry"/></mxCell></root></mxGraphModel></diagram><diagram id="cn7D_0s94JXZDTQf73YE" name="HotelBooking"><mxGraphModel dx="1845" dy="894" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="0" pageScale="1" pageWidth="850" pageHeight="1100" math="0" shadow="0"><root><mxCell id="0"/><mxCell id="1" parent="0"/><mxCell id="bZmsTk0F5IX-J39mtfF_-1" value="Hotel App" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;fontColor=#333333;strokeColor=#666666;" parent="1" vertex="1"><mxGeome